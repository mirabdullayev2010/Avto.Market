<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Avto.Barakat</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
            /* Butun sahifa foni qora bo'lishi shart */
            body {
                background-color: #0a0a0a;
                color: #ffffff;
                margin: 0;
                padding: 0;
            }

            /* Navbarni qora va zamonaviy qilish */
            .navbar-premium {
                background-color: #000000 !important;
                border-bottom: 1px solid #1a1a1a;
                padding: 15px 0;
            }

            .navbar-brand span {
                color: #d4af37;
            }
        
            /* O'rtadagi linklar stili */
            .nav-link-premium {
                color: #888 !important;
                font-weight: 500;
                text-transform: uppercase;
                letter-spacing: 1.5px;
                font-size: 0.85rem;
                transition: 0.3s;
                margin: 0 15px;
            }

                .nav-link-premium:hover {
                    color: #d4af37 !important;
                }

            /* Admin Panel tugmasi - Premium Style */
            .btn-admin-premium {
                background: rgba(212, 175, 55, 0.05);
                color: #d4af37;
                border: 1px solid rgba(212, 175, 55, 0.5);
                border-radius: 4px; /* Burchakli dizayn */
                padding: 8px 22px;
                text-transform: uppercase;
                font-weight: 600;
                font-size: 0.75rem;
                letter-spacing: 1px;
                transition: all 0.4s ease;
                text-decoration: none;
                display: inline-block;
            }

                .btn-admin-premium:hover {
                    background: #d4af37;
                    color: #0a0a0a;
                    box-shadow: 0 0 20px rgba(212, 175, 55, 0.3);
                    transform: translateY(-2px);
                }

            /* Footer stili */
            footer {
                background-color: #050505;
                border-top: 1px solid #151515;
                color: #555;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-premium">
            <div class="container">
                <a class="navbar-brand fw-bold fs-3 text-white" asp-controller="Home" asp-action="Index">
                    AVTO.<span>BARAKAT</span>
                </a>

                <button class="navbar-toggler navbar-dark" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link nav-link-premium" asp-controller="Home" asp-action="Index">Asosiy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-premium" asp-controller="Cars" asp-action="Index">Moshinalar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-premium" asp-controller="Categories" asp-action="Index">Kategoriyalar</a>
                        </li>
                    </ul>
                    
                    <div class="d-flex">
                        <a href="/Admin/Index" class="btn btn-admin-premium">
                            Admin Panel
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="py-5 mt-auto">
        <div class="container text-center text-white-50">
            <p class="mb-0">&copy; 2026 - <span style="color: #d4af37; font-weight: bold;">Avto.Barakat</span></p>
            <small class="opacity-50 text-uppercase" style="letter-spacing: 2px;">Sifat va Ishonch ramzi</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>