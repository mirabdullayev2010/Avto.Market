@model IEnumerable<Avto.Market.Shared.DTOs.Car.CarForResultDto>

<style>
    .hero-glass {
        background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?q=80&w=2070');
        background-size: cover; height: 450px; border-radius: 35px;
        display: flex; align-items: center; justify-content: center; color: white;
    }
    .car-card { 
        border-radius: 20px; border: none; transition: 0.4s; background: #fff; 
    }
    .car-card:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
    .price-tag { 
        background: #d4af37; color: black; font-weight: bold; 
        padding: 4px 12px; border-radius: 50px; position: absolute; bottom: 15px; right: 15px;
    }
</style>

<div class="container pb-5">
    <div class="d-flex justify-content-between align-items-center py-4">
        <h3 class="fw-bold m-0">AVTO.<span style="color: #d4af37;">BARAKAT</span></h3>
        <a href="/Admin/Index" class="btn btn-dark rounded-pill px-4 shadow-sm">Admin Panel</a>
    </div>

    <div class="hero-glass shadow-lg mb-5">
        <div class="text-center">
            <h1 class="display-3 fw-bold mb-0">AVTO <span style="color: #d4af37;">BARAKAT</span></h1>
            <p class="lead opacity-75">Sizning orzungizdagi sifatli avtomobillar</p>
            <a href="#inventory" class="btn btn-outline-light rounded-pill px-5 py-2 mt-3">Katalogni ko'rish</a>
        </div>
    </div>

    <div id="inventory" class="row g-4">
        @foreach (var car in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card car-card shadow-sm h-100">
                    <div class="position-relative overflow-hidden" style="border-radius: 20px 20px 0 0;">
                        <img src="@car.ImagePath" class="card-img-top" style="height: 240px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/400x250?text=Rasm+Topilmadi'">
                        <div class="price-tag shadow">$@car.Price.ToString("N0")</div>
                    </div>
                    <div class="card-body p-4 text-center">
                        <h4 class="fw-bold mb-1">@car.Brend</h4>
                        <p class="text-muted small">@car.Year - yil • A'lo holatda</p>
                        <a href="/Cars/Details/@car.Id" class="btn btn-outline-dark w-100 rounded-pill py-2">Batafsil ma'lumot</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>